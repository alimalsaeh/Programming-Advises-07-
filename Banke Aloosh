vector<string> SplitTokenInVector(string S1,string delim="#\\#") {
	string S2;
	vector<string> V1;
	short pos = 0;
	while ((pos = S1.find(delim)) != std::string::npos) {
		S2 = S1.substr(0, pos);
		if (S2 != "")
			V1.push_back(S2);
		S1.erase(0, pos + delim.length());
	}
